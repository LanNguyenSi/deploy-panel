generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Servers ─────────────────────────────────────────────────────────────────

model Server {
  id          String   @id @default(uuid())
  name        String
  host        String   @unique
  sshKeyPath  String?
  relayUrl    String?
  relayToken  String?
  // SHA-256 fingerprint (base64) of the SSH host key captured during
  // the onboarding probe. Re-install pins this: if the VPS was rebuilt
  // between first-install and re-install, the fingerprint diverges and
  // ssh-executor refuses the handshake with `host_key_rejected`.
  // Legacy rows (pre-2026-04-24 wizard) carry null → re-install falls
  // back to TOFU for those.
  hostKeySha256 String?
  // Resolved RELAY_MODE from the last install, parsed out of install.sh
  // v0.2.0+'s `Mode:` output line. The re-install UI defaults to this
  // so operators don't have to remember what the original install used.
  // Null for v0.1.x installers (no Mode line to parse).
  relayMode   String?
  // Directory on the VPS where agent-relay's docker-compose.yml lives.
  // install.sh defaults to /opt/agent-relay but accepts a custom
  // RELAY_DIR env var; operators who installed manually or under a
  // custom path (e.g. /root/git/agent-relay) need the update-image
  // and re-install flows to know where. Null = fall back to
  // /opt/agent-relay. The value is validated as an absolute path with
  // no shell metachars before being templated into SSH commands.
  relayDir    String?
  status      String   @default("unknown") // unknown, online, offline, no-relay
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Ownership. Non-null for broker-registered users (they only see their own).
  // Null = admin-shared (visible to panel-token / session admins; legacy rows
  // before this migration also land here). Ownership propagates via serverId
  // to App, Deploy, EnvVarChange, and ScheduledDeploy — those don't carry
  // their own userId; their access is gated through this FK.
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  apps             App[]
  deploys          Deploy[]
  scheduledDeploys ScheduledDeploy[]

  @@index([userId])
  @@map("servers")
}

// ── Apps ─────────────────────────────────────────────────────────────────────

model App {
  id           String   @id @default(uuid())
  serverId     String
  name         String
  repoUrl      String?
  branch       String   @default("main")
  path         String   // path on VPS
  health       String?  // health endpoint
  liveUrl      String?  // public URL to the deployed app (manual; not derivable from the relay)
  status       String   @default("unknown") // unknown, healthy, unhealthy, deploying
  tag          String?  // production, development, ignored
  lastDeployAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  deploys      Deploy[]
  envChanges   EnvVarChange[]

  @@unique([serverId, name])
  @@map("apps")
}

// ── Env-var change log ──────────────────────────────────────────────────────
// Records that a given key changed on an app, without ever storing the value.
// The live value lives on the VPS in the app's .env file; the panel only
// proxies reads/writes. This table is purely for "who changed what and when".
model EnvVarChange {
  id         String   @id @default(uuid())
  appId      String
  key        String
  changeType String   // "create" | "update" | "delete"
  actor      String?
  createdAt  DateTime @default(now())

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
  @@index([appId, key])
  @@map("env_var_changes")
}

// ── Users ───────────────────────────────────────────────────────────────────
// Minimal multi-user layer provisioned via the identity-broker endpoint
// (project-pilot). deploy-panel doesn't yet expose per-user UIs or per-user
// deployment isolation — this table exists so that broker-issued API keys
// can be attributed to a real identity for audit / later RBAC work. The
// original PANEL_TOKEN single-secret flow remains the fallback for direct
// admin access.
model User {
  id          String   @id @default(uuid())
  githubId    String   @unique
  githubLogin String
  email       String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apiKeys     ApiKey[]
  servers     Server[]
  sessions    Session[]
  auditLogs   AuditLog[]

  @@map("users")
}

// Browser sessions issued by the native GitHub OAuth flow. Distinct from
// the legacy `panel_session` cookie that carries the raw PANEL_TOKEN
// string — those still work for admin access. A Session row is the
// canonical proof-of-login for broker-registered users who sign in
// directly at deploy-panel.
model Session {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ── API Keys ────────────────────────────────────────────────────────────────

model ApiKey {
  id         String   @id @default(uuid())
  name       String   // e.g. "github-actions-prod"
  keyHash    String   @unique // SHA-256 hash of the key
  keyPrefix  String   // first 8 chars for display (dp_xxxx...)
  userId     String?  // null = admin-created panel-wide key (legacy flow)
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

// ── Deploys ─────────────────────────────────────────────────────────────────

model Deploy {
  id           String   @id @default(uuid())
  serverId     String
  appId        String
  commitBefore String?
  commitAfter  String?
  status       String   @default("pending") // pending, running, success, failed, rolled_back
  duration     Int?     // milliseconds
  log          String?  // full deploy output
  triggeredBy  String?  // "panel", "mcp", "api"
  createdAt    DateTime @default(now())

  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  app          App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
  @@index([serverId])
  @@map("deploys")
}

// ── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // deploy, rollback, server.create, server.delete, app.tag, app.hide, login, logout, api_key.create, api_key.revoke
  target    String?  // e.g. "deploy-panel on VPS-01" or "VPS-01 (Stone)"
  detail    String?  // extra info like commit hash, status, etc.
  actor     String?  // free-form label kept for UI display: "panel", "api:github-actions", "session", "broker:project-pilot/<login>"
  // Structured actor, populated when the triggering credential is bound
  // to a User (broker API keys, native OAuth sessions). Null for
  // admin-triggered actions via PANEL_TOKEN / session-as-admin and for
  // pre-migration rows. Non-admin `/api/audit` callers filter on this;
  // admins see everything regardless.
  actorUserId String?
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([actorUserId])
  @@map("audit_logs")
}

// ── Scheduled Deploys ───────────────────────────────────────────────────────

model ScheduledDeploy {
  id        String   @id @default(uuid())
  serverId  String
  appName   String
  scheduledFor DateTime
  force     Boolean  @default(false)
  status    String   @default("pending") // pending, triggered, cancelled
  deployId  String?  // linked deploy once triggered
  createdAt DateTime @default(now())

  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([scheduledFor])
  @@index([status])
  @@map("scheduled_deploys")
}
