generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Servers ─────────────────────────────────────────────────────────────────

model Server {
  id          String   @id @default(uuid())
  name        String
  host        String   @unique
  sshKeyPath  String?
  relayUrl    String?
  relayToken  String?
  status      String   @default("unknown") // unknown, online, offline, no-relay
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apps             App[]
  deploys          Deploy[]
  scheduledDeploys ScheduledDeploy[]

  @@map("servers")
}

// ── Apps ─────────────────────────────────────────────────────────────────────

model App {
  id           String   @id @default(uuid())
  serverId     String
  name         String
  repoUrl      String?
  branch       String   @default("main")
  path         String   // path on VPS
  health       String?  // health endpoint
  status       String   @default("unknown") // unknown, healthy, unhealthy, deploying
  tag          String?  // production, development, ignored
  lastDeployAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  deploys      Deploy[]

  @@unique([serverId, name])
  @@map("apps")
}

// ── API Keys ────────────────────────────────────────────────────────────────

model ApiKey {
  id         String   @id @default(uuid())
  name       String   // e.g. "github-actions-prod"
  keyHash    String   @unique // SHA-256 hash of the key
  keyPrefix  String   // first 8 chars for display (dp_xxxx...)
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())

  @@map("api_keys")
}

// ── Deploys ─────────────────────────────────────────────────────────────────

model Deploy {
  id           String   @id @default(uuid())
  serverId     String
  appId        String
  commitBefore String?
  commitAfter  String?
  status       String   @default("pending") // pending, running, success, failed, rolled_back
  duration     Int?     // milliseconds
  log          String?  // full deploy output
  triggeredBy  String?  // "panel", "mcp", "api"
  createdAt    DateTime @default(now())

  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  app          App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
  @@index([serverId])
  @@map("deploys")
}

// ── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // deploy, rollback, server.create, server.delete, app.tag, app.hide, login, logout, api_key.create, api_key.revoke
  target    String?  // e.g. "deploy-panel on VPS-01" or "VPS-01 (Stone)"
  detail    String?  // extra info like commit hash, status, etc.
  actor     String?  // "panel", "api:github-actions", "session"
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Scheduled Deploys ───────────────────────────────────────────────────────

model ScheduledDeploy {
  id        String   @id @default(uuid())
  serverId  String
  appName   String
  scheduledFor DateTime
  force     Boolean  @default(false)
  status    String   @default("pending") // pending, triggered, cancelled
  deployId  String?  // linked deploy once triggered
  createdAt DateTime @default(now())

  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([scheduledFor])
  @@index([status])
  @@map("scheduled_deploys")
}
